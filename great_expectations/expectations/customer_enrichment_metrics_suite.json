      "meta": {"rule_name": "lifetime_value_non_negative", "rule_type": "consistency", "severity": "ERROR"}
    },
    {
      "expectation_type": "expect_column_max_to_be_recent",
      "kwargs": {"column": "calculated_at", "max_age_hours": 24, "mostly": 1.0},
      "meta": {"rule_name": "customer_enrichment_metrics_freshness_24h", "rule_type": "freshness", "severity": "ERROR"}
    }
  ],
  "meta": {
    "notes": "Production quality suite for daily customer enrichment metrics.",
    "table_name": "CUSTOMER360_DB.GOLD.customer_enrichment_metrics",
    "owner": "customer360-data-engineering"
