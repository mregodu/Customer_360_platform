      "meta": {"rule_name": "product_adoption_score_between_zero_and_one", "rule_type": "validity", "severity": "ERROR"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "engagement_score", "min_value": 0, "max_value": 1, "allow_null": true, "mostly": 1.0},
      "meta": {"rule_name": "engagement_score_between_zero_and_one", "rule_type": "validity", "severity": "ERROR"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "support_health_score", "min_value": 0, "max_value": 1, "allow_null": true, "mostly": 1.0},
      "meta": {"rule_name": "support_health_score_between_zero_and_one", "rule_type": "validity", "severity": "ERROR"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "renewal_probability", "min_value": 0, "max_value": 1, "allow_null": true, "mostly": 1.0},
      "meta": {"rule_name": "renewal_probability_between_zero_and_one", "rule_type": "validity", "severity": "ERROR"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
