# Customer 360 container environment template.
# Copy this file to `.env` for local Docker Compose runs. Do not commit `.env`.

CUSTOMER360_ENV=dev
CUSTOMER360_IMAGE_TAG=local
CUSTOMER360_DOMO_DRY_RUN=true

# Airflow runtime.
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_FERNET_KEY=x5Gj92yendFUZ_1ylXhbamH1H1wiqNfVyU66U0edp_s=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Customer
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Airflow metadata database.
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow

# Snowflake connectivity. Use a least-privilege service user for deployed environments.
SNOWFLAKE_ACCOUNT=local-dev
SNOWFLAKE_USER=customer360_dev
SNOWFLAKE_PASSWORD=local_password
SNOWFLAKE_ROLE=CUSTOMER360_DEV_ROLE
SNOWFLAKE_WAREHOUSE=CUSTOMER360_DEV_WH

# Source-system API settings used by configs/prod.yaml.
SALESFORCE_API_BASE_URL=
SALESFORCE_API_TOKEN=
MARKETO_API_BASE_URL=
MARKETO_API_TOKEN=
ZENDESK_API_BASE_URL=
ZENDESK_API_TOKEN=
PRODUCT_USAGE_API_BASE_URL=
PRODUCT_USAGE_API_TOKEN=
LICENSING_API_BASE_URL=
LICENSING_API_TOKEN=
IMPARTNER_API_BASE_URL=
IMPARTNER_API_TOKEN=

# Domo publishing. Keep dry-run enabled until Domo dataset IDs are configured.
DOMO_API_HOST=https://api.domo.com
DOMO_CLIENT_ID=dev_domo_client_id
DOMO_CLIENT_SECRET=dev_domo_client_secret
DOMO_ACCESS_TOKEN=

# Optional Domo dataset IDs, required only when CUSTOMER360_DOMO_DRY_RUN=false.
DOMO_DATASET_ID_CUSTOMER360_DEV_CUSTOMER_HEALTH_SCORES=
DOMO_DATASET_ID_CUSTOMER360_DEV_EXECUTIVE_CUSTOMER_KPIS_DAILY=
DOMO_DATASET_ID_CUSTOMER360_DEV_EXECUTIVE_SEGMENT_HEALTH_DAILY=
DOMO_DATASET_ID_CUSTOMER360_DEV_CUSTOMER_SUCCESS_ACCOUNT_DAILY=
DOMO_DATASET_ID_CUSTOMER360_DEV_CUSTOMER_HEALTH_DRILLDOWN=
DOMO_DATASET_ID_CUSTOMER360_DEV_PARTNER_PERFORMANCE_DAILY=
DOMO_DATASET_ID_CUSTOMER360_DEV_DATA_QUALITY_DASHBOARD_DAILY=
